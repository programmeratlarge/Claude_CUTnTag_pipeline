/*
========================================================================================
    conf/slurm.config — SLURM executor settings
    Tested on Cornell BioHPC. Override params at run time:
      --slurm_partition  regular   (default: 'regular')
      --slurm_account    ''        (default: empty; set if your site requires --account)
========================================================================================
*/

params.slurm_partition = params.slurm_partition ?: 'regular'
params.slurm_account   = params.slurm_account   ?: ''

process {
    executor       = 'slurm'
    queue          = "${params.slurm_partition}"
    clusterOptions = params.slurm_account ? "--account=${params.slurm_account}" : ''
    scratch        = '/workdir/${USER}/tmp'   // ${USER} expanded by SLURM/Bash at task time
}

executor {
    queueSize       = 100
    submitRateLimit = '10 sec'
}
