/*
========================================================================================
    conf/slurm.config — SLURM executor settings
    Defaults for slurm_partition / slurm_account live in nextflow.config's params block.
    Override at run time, e.g.:
      nextflow run main.nf -profile slurm,singularity --slurm_partition long --slurm_account labX ...
========================================================================================
*/

process {
    executor       = 'slurm'
    queue          = "${params.slurm_partition}"
    clusterOptions = params.slurm_account ? "--account=${params.slurm_account}" : ''
    scratch        = '/workdir/${USER}/tmp'   // ${USER} expanded by SLURM/Bash at task time
}

executor {
    queueSize       = 100
    submitRateLimit = '10 sec'
}
