/*
========================================================================================
    conf/singularity.config — Singularity / Apptainer container assignments
    (Recommended on Cornell BioHPC; load with: module load nextflow/25.4.3)
========================================================================================
*/

singularity {
    enabled       = true
    autoMounts    = true
    cacheDir      = "${System.getenv('NXF_SINGULARITY_CACHEDIR') ?: '/workdir/' + System.getenv('USER') + '/.singularity_cache'}"
    runOptions    = '--cleanenv'
}

process {
    withName: 'FASTQC.*'              { container = 'https://depot.galaxyproject.org/singularity/fastqc:0.12.1--hdfd78af_0' }
    withName: 'MULTIQC.*'             { container = 'https://depot.galaxyproject.org/singularity/multiqc:1.25.1--pyhdfd78af_0' }
    withName: 'CUTADAPT'              { container = 'https://depot.galaxyproject.org/singularity/cutadapt:4.9--py312hf67a6ed_0' }
    withName: 'BOWTIE2_ALIGN'         { container = 'https://depot.galaxyproject.org/singularity/mulled-v2-c742dccc9d8fabfcff2af0d8d6799dbc711366cf:b6524911af823c7c52518f6c886b86916d062940-0' }
    withName: 'SAMTOOLS.*'            { container = 'https://depot.galaxyproject.org/singularity/samtools:1.20--h50ea8bc_0' }
    withName: 'FILTER_MITO_BLACKLIST' { container = 'https://depot.galaxyproject.org/singularity/mulled-v2-9d3a458f6420e5712103ae2af82c94d26d63f059:60b54b43045e8cf39ba307fd683c897d3f8cbee3-0' }
    withName: 'MARK_DUPLICATES'       { container = 'https://depot.galaxyproject.org/singularity/picard:3.2.0--hdfd78af_0' }
    withName: 'UMI_DEDUP'             { container = 'https://depot.galaxyproject.org/singularity/umi_tools:1.1.5--py312h1f1cfbb_2' }
    withName: 'BAMCOVERAGE'           { container = 'https://depot.galaxyproject.org/singularity/deeptools:3.5.5--pyhdfd78af_0' }
    withName: 'COMPUTE_MATRIX.*'      { container = 'https://depot.galaxyproject.org/singularity/deeptools:3.5.5--pyhdfd78af_0' }
    withName: 'PLOT_PROFILE'          { container = 'https://depot.galaxyproject.org/singularity/deeptools:3.5.5--pyhdfd78af_0' }
    withName: 'PLOT_HEATMAP'          { container = 'https://depot.galaxyproject.org/singularity/deeptools:3.5.5--pyhdfd78af_0' }
    withName: 'BIGWIG_TO_BEDGRAPH'    { container = 'https://depot.galaxyproject.org/singularity/ucsc-bigwigtobedgraph:469--h664eb37_0' }
    withName: 'MACS3.*'               { container = 'https://depot.galaxyproject.org/singularity/macs3:3.0.2--py312hf67a6ed_0' }
    withName: 'MERGE_BAMS'            { container = 'https://depot.galaxyproject.org/singularity/samtools:1.20--h50ea8bc_0' }
    withName: 'CONSENSUS_PEAKS'       { container = 'https://depot.galaxyproject.org/singularity/bedtools:2.31.1--hf5e1c6e_2' }
    withName: 'ANNOTATE_PEAKS'        { container = 'https://depot.galaxyproject.org/singularity/bioconductor-chipseeker:1.40.0--r44hdfd78af_0' }
    withName: 'FRIP.*'                { container = 'https://depot.galaxyproject.org/singularity/mulled-v2-9d3a458f6420e5712103ae2af82c94d26d63f059:60b54b43045e8cf39ba307fd683c897d3f8cbee3-0' }
    withName: 'READ_RETENTION'        { container = 'https://depot.galaxyproject.org/singularity/python:3.11' }
    withName: 'DETECT_FASTQ_PAIRS'    { container = 'https://depot.galaxyproject.org/singularity/python:3.11' }
    withName: 'VALIDATE_ASSOCIATIONS' { container = 'https://depot.galaxyproject.org/singularity/python:3.11' }
}
