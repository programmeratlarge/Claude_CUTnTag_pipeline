/*
========================================================================================
    conf/base.config — default process resources by label
========================================================================================
*/

process {

    // Default resource allocation
    cpus     = { check_max( 2     * task.attempt, 'cpus'  ) }
    memory   = { check_max( 4.GB  * task.attempt, 'memory') }
    time     = { check_max( 4.h   * task.attempt, 'time'  ) }

    errorStrategy = { task.exitStatus in ((130..145) + 104 + [125,137,139,140]) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Publishing
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_mode,
        saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
    ]

    // ------------------- Resource labels -------------------
    withLabel: process_low {
        cpus   = { check_max( 2     * task.attempt, 'cpus'  ) }
        memory = { check_max( 4.GB  * task.attempt, 'memory') }
        time   = { check_max( 2.h   * task.attempt, 'time'  ) }
    }
    withLabel: process_medium {
        cpus   = { check_max( 6     * task.attempt, 'cpus'  ) }
        memory = { check_max( 16.GB * task.attempt, 'memory') }
        time   = { check_max( 8.h   * task.attempt, 'time'  ) }
    }
    withLabel: process_high {
        cpus   = { check_max( 12    * task.attempt, 'cpus'  ) }
        memory = { check_max( 48.GB * task.attempt, 'memory') }
        time   = { check_max( 24.h  * task.attempt, 'time'  ) }
    }
    withLabel: process_long {
        time   = { check_max( 36.h  * task.attempt, 'time'  ) }
    }

    // ------------------- Per-process overrides ------------------
    withName: 'BOWTIE2_ALIGN'           { label 'process_high' }
    withName: 'SAMTOOLS_SORT_INDEX'     { label 'process_medium' }
    withName: 'MARK_DUPLICATES'         { label 'process_medium' }
    withName: 'UMI_DEDUP'               { label 'process_medium' }
    withName: 'BAMCOVERAGE'             { label 'process_medium' }
    withName: 'COMPUTE_MATRIX_TSS'      { label 'process_high' }
    withName: 'COMPUTE_MATRIX_PEAKS'    { label 'process_high' }
    withName: 'MACS3_PER_SAMPLE'        { label 'process_medium' }
    withName: 'MACS3_GROUP'             { label 'process_medium' }
    withName: 'CUTADAPT'                { label 'process_medium' }
    withName: 'FILTER_MITO_BLACKLIST'   { label 'process_medium' }
    withName: 'MULTIQC.*'               { label 'process_low' }
    withName: 'FASTQC.*'                { label 'process_low' }
}
