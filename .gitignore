# Nextflow runtime artefacts
work/
.nextflow*
*.command.*
trace-*.txt
timeline-*.html
report-*.html
dag-*.html

# Outputs (these go under /workdir/$USER/cuttag_run/results, but don't accidentally
# commit a local results/ either)
results/
test/results/
test/fastq/
test/refs/

# Editor / OS artefacts
.DS_Store
.idea/
.vscode/
*.swp
*~

# Python
__pycache__/
*.pyc
*.egg-info/

# R
.Rhistory
.RData
.Ruserdata

# Singularity / Docker caches (should live under /workdir/$USER/.singularity_cache,
# but never commit any container blob)
.singularity_cache/
*.sif
*.simg
