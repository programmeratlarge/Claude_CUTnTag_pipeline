/*
========================================================================================
    nextflow.config — CUT&Tag DSL2 Pipeline
========================================================================================
*/

manifest {
    name            = 'cuttag-dsl2'
    author          = 'Senior Bioinformatics Pipeline Architect'
    description     = 'Production-grade paired-end CUT&Tag analysis pipeline (Nextflow DSL2)'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version         = '1.0.0'
    homePage        = 'https://github.com/example/cuttag-dsl2'
}

// ----------------------------------------------------------------------------
// Default parameters — override on the command line or via -params-file
// ----------------------------------------------------------------------------
params {
    // ---- Required (no defaults) ----
    input_dir        = null
    outdir           = null
    genome           = null
    bowtie2_index    = null
    chrom_sizes      = null
    annotation_gtf   = null
    tss_bed          = null
    association_csv  = null

    // ---- Optional inputs ----
    blacklist        = null

    // ---- Pairing / IO ----
    paired_pattern   = 'auto'           // auto | regex like '(.*)_R[12]_001\\.fastq\\.gz'

    // ---- Trimming (Nextera/Tn5 defaults — Tn5 dimerizes with Nextera adapters in CUT&Tag) ----
    adapter_fwd      = 'CTGTCTCTTATACACATCT'
    adapter_rev      = 'CTGTCTCTTATACACATCT'
    min_read_length  = 20

    // ---- Alignment / filtering ----
    bowtie2_args     = '--end-to-end --very-sensitive --no-mixed --no-discordant --phred33 -I 10 -X 700'
    mapq             = 30
    mito_chroms      = 'chrM,MT,M,Mt,mitochondrion'
    use_umi          = false
    umi_pattern      = 'NNNNNN'

    // ---- Peak calling ----
    macs_qvalue      = 0.05
    genome_size      = 'hs'             // hs | mm | rn | dm | ce | <int>
    allow_no_control = false

    // ---- Signal tracks ----
    bigwig_binsize         = 10
    bigwig_norm            = 'CPM'            // CPM | RPGC | RPKM | BPM | None
    effective_genome_size  = 2913022398       // hg38 default; override for other genomes (mm10=2652783500, mm39=2654621837, dm6=142573017)

    // ---- Plots / matrices ----
    tss_window       = 3000
    peak_window      = 3000

    // ---- Compute caps ----
    threads          = 8
    max_memory       = '64.GB'
    max_cpus         = 16
    max_time         = '48.h'

    // ---- SLURM (only used by -profile slurm) ----
    slurm_partition  = 'regular'
    slurm_account    = null              // set to a non-null value to add --account=<X>

    // ---- Misc ----
    help             = false
    publish_mode     = 'copy'
    tracedir         = "${params.outdir}/pipeline_info"
}

// ----------------------------------------------------------------------------
// Process-level defaults / labels
// ----------------------------------------------------------------------------
includeConfig 'conf/base.config'

// ----------------------------------------------------------------------------
// Profiles
// ----------------------------------------------------------------------------
profiles {
    standard {
        process.executor = 'local'
    }
    local {
        process.executor = 'local'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
    docker {
        includeConfig 'conf/docker.config'
    }
    singularity {
        includeConfig 'conf/singularity.config'
    }
    apptainer {
        includeConfig 'conf/singularity.config'
        singularity.engineOptions = ''
        apptainer.enabled = true
        singularity.enabled = false
    }
    conda {
        conda.enabled = true
        useMamba = true
        process.conda = "${projectDir}/environment.yml"
    }
    test {
        params.input_dir       = "${projectDir}/test/fastq"
        params.outdir          = "${projectDir}/test/results"
        params.genome          = 'hg38'
        params.association_csv = "${projectDir}/test/test_associations.csv"
        process.cpus           = 2
        process.memory         = '4 GB'
    }
    debug {
        process.beforeScript = 'echo "[DEBUG] $HOSTNAME pwd=$(pwd) | $(date)"'
    }
}

// ----------------------------------------------------------------------------
// Reporting / reproducibility
// ----------------------------------------------------------------------------
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline_${trace_timestamp}.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report_${trace_timestamp}.html"
    overwrite = true
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace_${trace_timestamp}.txt"
    overwrite = true
    fields  = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}
dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag_${trace_timestamp}.html"
    overwrite = true
}

// ----------------------------------------------------------------------------
// Resource cap helper
// ----------------------------------------------------------------------------
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj as int, params.max_cpus as int)
        } catch (all) { return obj }
    }
}
